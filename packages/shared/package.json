{
  "name": "@uberwal/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, validation, namespace helpers, and the MemWalClient wrapper used by the MCP server and dashboard.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
